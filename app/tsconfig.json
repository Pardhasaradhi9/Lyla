{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@/engines/*": [
        "src/engines/*"
      ],
      "@/db/*": [
        "src/db/*"
      ],
      "@/stores/*": [
        "src/stores/*"
      ],
      "@/components/*": [
        "src/components/*"
      ],
      "@/prompts/*": [
        "src/prompts/*"
      ],
      "@/utils/*": [
        "src/utils/*"
      ],
      "@/theme/*": [
        "src/theme/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
